        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "((sum by (user_id) (increase(loki_process_custom_gen_ai_usage_cost_micro_usd{service_name=\"envoy-ai-gateway\", azp=~\"$azp\", model=~\"$model\"}[$__range]))) / 1e6)",
          "refId": "A",
          "instant": true,
          "range": false,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          }
        },
        {
          "expr": "sum by (user_id) (increase(loki_process_custom_gen_ai_requests{service_name=\"envoy-ai-gateway\", azp=~\"$azp\", model=~\"$model\"}[$__range]))",
          "refId": "C",
          "instant": true,
          "range": false,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          }
        },
        {
          "refId": "B",
          "datasource": {
            "type": "postgres",
            "uid": "keycloak"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT id AS user_id, username, email, NULLIF(TRIM(COALESCE(first_name, '') || ' ' || COALESCE(last_name, '')), '') AS name FROM user_entity WHERE realm_id = '04793949-13aa-48ef-9d4d-1c60761f0c97'"
        }
      ],
      "title": "Spend by user — resolved to identity (selected range)",
      "transparent": false,
