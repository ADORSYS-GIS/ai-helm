      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "account_id": "Account",
              "model": "Model",
              "plan": "Plan",
              "plane": "Plane",
              "Value #A": "Spend ($)"
            },
            "excludeByName": {
              "Time": true,
              "window": true
            },
            "indexByName": {
              "account_id": 0,
              "model": 1,
              "plan": 2,
              "plane": 3,
              "Value #A": 4
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Spend ($)",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Spend ($)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          }
        ]
