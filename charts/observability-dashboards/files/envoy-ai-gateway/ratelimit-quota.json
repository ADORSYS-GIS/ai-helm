      "targets": [
        {
          "expr": "((sum by (account_id, model, plan, plane) (gateway_ratelimit_spend_micro_usd{window=~\"$window\", plan=~\"$plan\", model=~\"$model\", account_id=~\"$account\"})) / 1e6)",
