    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "Live limiter census — direct from Redis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 40
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "redis-datasource",
            "uid": "redis-ratelimit"
          },
          "type": "command",
          "command": "tmscan",
          "match": "*-match-0*",
          "count": 2000,
          "size": 2000
        }
      ],
      "title": "Live limiter counters — direct from Redis (zero scrape-lag)",
      "transparent": false,
      "datasource": {
        "type": "redis-datasource",
        "uid": "redis-ratelimit"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "key",
            "format": "regex",
            "regExp": "/converse/(?<Model>[^/]+)/.*_rule-\\d+-match-0_(?<Account>.+?)_rule-\\d+-match-1",
            "keepFields": true
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "key": "Redis key"
            },
            "excludeByName": {
              "type": true,
              "memory": true,
              "cursor": true,
              "count": true
            },
            "indexByName": {
              "Account": 0,
              "Model": 1,
              "Redis key": 2
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": []
      }
    }
