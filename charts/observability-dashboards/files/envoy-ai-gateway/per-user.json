{
  "title": "AI Gateway — per-user activity",
  "uid": "envoy-ai-gateway-per-user",
  "tags": ["ai-gateway", "per-user", "loki"],
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "6h"] },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "azp",
        "label": "Client (azp)",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "azp", "type": 1 },
        "definition": "label_values(azp)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "user_id",
        "label": "User",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "user_id", "type": 1 },
        "definition": "label_values({azp=~\"$azp\"}, user_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "gen_ai_request_model", "type": 1 },
        "definition": "label_values(gen_ai_request_model)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "sort": 1,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue" } ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" [$__range]))",
          "queryType": "range",
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique users (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "purple" } ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count(sum by (user_id) (count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" [$__range])))",
          "queryType": "range",
          "instant": false
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total tokens (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" } ] }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | unwrap gen_ai_usage_total_tokens [$__range]))",
          "queryType": "range",
          "instant": false
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | unwrap duration [$__range])",
          "queryType": "range",
          "instant": false
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests per user / minute",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (user_id) (count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" [1m]))",
          "legendFormat": "{{user_id}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top users by requests",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } }
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(20, sum by (user_id, azp) (count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" [$__range])))",
          "queryType": "instant",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "Requests" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Model distribution (selected scope)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (gen_ai_request_model) (count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" [$__range]))",
          "legendFormat": "{{gen_ai_request_model}}",
          "queryType": "instant",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency per user — p50 / p95",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0, "showPoints": "never" },
          "unit": "ms"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.50, {azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | unwrap duration [5m]) by (user_id)",
          "legendFormat": "p50 {{user_id}}",
          "queryType": "range"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | unwrap duration [5m]) by (user_id)",
          "legendFormat": "p95 {{user_id}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Failed requests per user (5xx)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 0, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (user_id) (count_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | response_code >= 500 [1m]))",
          "legendFormat": "{{user_id}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Token usage per user (total)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "showPoints": "never" },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (user_id) (sum_over_time({azp=~\"$azp\", user_id=~\"$user_id\"} | json | gen_ai_request_model =~ \"$model\" | unwrap gen_ai_usage_total_tokens [1m]))",
          "legendFormat": "{{user_id}}",
          "queryType": "range"
        }
      ]
    }
  ],
  "description": "Per-user activity for the Envoy AI Gateway. Data flows: JWT -> Authorino response headers (x-cd-user-id, x-cd-azp) -> Envoy access log JSON -> OTLP -> Alloy loki.process 'ai_gateway_user_attribution' -> Loki labels (user_id, azp). See docs/per-user-observability.md."
}
