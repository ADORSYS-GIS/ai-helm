    {
      "type": "table",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "keycloak"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ue.username, NULLIF(TRIM(COALESCE(ue.first_name, '') || ' ' || COALESCE(ue.last_name, '')), '') AS name, c.client_id AS client, to_timestamp(ous.created_on) AS created, to_timestamp(ocs.timestamp) AS last_active, round(EXTRACT(EPOCH FROM (now() - to_timestamp(ocs.timestamp))) / 86400, 1) AS idle_days FROM offline_user_session ous JOIN user_entity ue ON ue.id = ous.user_id JOIN offline_client_session ocs ON ocs.user_session_id = ous.user_session_id AND ocs.offline_flag = '1' JOIN client c ON c.id = ocs.client_id WHERE ous.realm_id = '04793949-13aa-48ef-9d4d-1c60761f0c97' AND ous.offline_flag = '1' ORDER BY ocs.timestamp DESC"
        }
      ],
